# Part 8 Stage 3 — 환경변수 예시. `.env` 로 복사하여 실제 값으로 교체.
# `.env` 는 gitignore 대상이므로 비밀키는 커밋되지 않습니다.

# ----- Python / 로깅 -----
PYTHON_VERSION=3.11
LOG_LEVEL=INFO

# ----- Ollama (기본 로컬 Provider) -----
OLLAMA_BASE_URL=http://localhost:11434
# 기본 3 모델: qwen3:8b (CTO) / gemma4:e4b (SLM) / llama3.2:3b (MLOps)
# HardwareProfile 을 바꾸면 대시보드 설정에서 자동 cascade 됩니다.

# ----- 외부 Provider API 키 (선택, HardwareProfile=CUSTOM + llm_provider 변경 시 필요) -----
# Anthropic Claude (2026-04 기준 한국어 JSON 안정성 최고 — 외부 Provider 권장 기본)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (대안)
# OPENAI_API_KEY=sk-...

# Google Gemini (대안)
# GEMINI_API_KEY=AIza...
